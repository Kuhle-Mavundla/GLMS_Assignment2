@model IEnumerable<Client>
@{ ViewData["Title"] = "Clients"; }
<h2>Clients</h2>
<p><a asp-action="Create" class="btn btn-primary">+ New Client</a></p>
<table class="table table-striped">
    <thead><tr><th>Name</th><th>Contact Details</th><th>Region</th><th></th></tr></thead>
    <tbody>
    @foreach (var item in Model) {
        <tr>
            <td>@item.Name</td><td>@item.ContactDetails</td><td>@item.Region</td>
            <td>
                <a asp-action="Details" asp-route-id="@item.ClientId" class="btn btn-sm btn-info">Details</a>
                <a asp-action="Edit" asp-route-id="@item.ClientId" class="btn btn-sm btn-warning">Edit</a>
                <a asp-action="Delete" asp-route-id="@item.ClientId" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>