@model ShipmentDemoViewModel
@{ ViewData["Title"] = "Design Pattern Demo"; }
<h2>Design Pattern Demo</h2>
<p class="text-muted">This page demonstrates the three Gang of Four design patterns from Part 1 working together in code.</p>

<form asp-action="Demo" method="post" class="card p-4 mb-4 bg-light border-0 shadow-sm">
    <div class="row">
        <div class="col-md-3 mb-3">
            <label asp-for="ShipmentType" class="form-label fw-bold">Shipment Type (Factory)</label>
            <select asp-for="ShipmentType" class="form-select" asp-items="Html.GetEnumSelectList<ShipmentType>()"></select>
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Origin" class="form-label">Origin</label>
            <input asp-for="Origin" class="form-control" placeholder="e.g. Johannesburg" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Destination" class="form-label">Destination</label>
            <input asp-for="Destination" class="form-control" placeholder="e.g. London" />
        </div>
        <div class="col-md-3 mb-3">
            <label asp-for="Cost" class="form-label">Cost</label>
            <input asp-for="Cost" class="form-control" type="number" step="0.01" />
        </div>
    </div>
    <div class="mb-3">
        <label asp-for="RoutingStrategy" class="form-label fw-bold">Routing Strategy (Strategy Pattern)</label>
        <select asp-for="RoutingStrategy" class="form-select">
            <option value="Fastest">Fastest Route</option>
            <option value="LeastCost">Least-Cost Route</option>
            <option value="EcoFriendly">Eco-Friendly Route</option>
        </select>
    </div>
    <button type="submit" class="btn btn-primary">Run Demo</button>
</form>

@if (Model.ShipmentDetails != null) {
    <div class="card mb-3 border-start border-primary border-4 shadow-sm">
        <div class="card-header bg-primary text-white fw-bold">1. Factory Method Pattern - Shipment Created</div>
        <div class="card-body"><code>@Model.ShipmentDetails</code></div>
    </div>
    <div class="card mb-3 border-start border-success border-4 shadow-sm">
        <div class="card-header bg-success text-white fw-bold">2. Strategy Pattern - Routing Calculated</div>
        <div class="card-body"><code>@Model.RoutingResult</code></div>
    </div>
    <div class="card mb-3 border-start border-warning border-4 shadow-sm">
        <div class="card-header bg-warning fw-bold">3. Observer Pattern - All Observers Notified</div>
        <div class="card-body">
            <ul class="list-unstyled mb-0">
                @if (Model.Notifications != null) {
                    @foreach (var n in Model.Notifications) {
                        <li class="mb-1"><code>@n</code></li>
                    }
                }
            </ul>
        </div>
    </div>
}