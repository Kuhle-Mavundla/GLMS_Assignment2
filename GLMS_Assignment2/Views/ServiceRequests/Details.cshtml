@model ServiceRequest
@{ ViewData["Title"] = "Service Request Details"; }
<h2>Service Request #@Model.ServiceRequestId</h2>
<dl class="row">
    <dt class="col-sm-3">Contract</dt><dd class="col-sm-9">#@Model.ContractId — @Model.Contract?.Client?.Name</dd>
    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Cost (USD)</dt>
    <dd class="col-sm-9">@Model.CostUSD.ToString("C", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</dd>
    <dt class="col-sm-3">Cost (ZAR)</dt><dd class="col-sm-9">R @Model.CostZAR.ToString("N2")</dd>
    <dt class="col-sm-3">Exchange Rate</dt><dd class="col-sm-9">@Model.ExchangeRateUsed.ToString("N6")</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge bg-info">@Model.Status</span></dd>
    <dt class="col-sm-3">Created</dt><dd class="col-sm-9">@Model.CreatedDate.ToShortDateString()</dd>
</dl>
<a asp-action="Index" class="btn btn-secondary">Back</a>