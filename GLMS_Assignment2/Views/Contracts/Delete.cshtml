@model Contract
@{ ViewData["Title"] = "Delete Contract"; }
<h2 class="text-danger">Delete Contract #@Model.ContractId</h2>
<p>Are you sure? This will also delete all associated service requests.</p>
<dl class="row">
    <dt class="col-sm-3">Client</dt><dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9">@Model.Status</dd>
</dl>
<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ContractId" />
    <button type="submit" class="btn btn-danger">Confirm Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>