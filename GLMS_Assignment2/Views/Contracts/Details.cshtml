@model Contract
@{ ViewData["Title"] = "Contract Details"; }
<h2>Contract #@Model.ContractId</h2>
<div class="card border-0 shadow-sm p-4 mb-4">
<dl class="row mb-0">
    <dt class="col-sm-3">Client</dt><dd class="col-sm-9">@Model.Client?.Name</dd>
    <dt class="col-sm-3">Start Date</dt><dd class="col-sm-9">@Model.StartDate.ToShortDateString()</dd>
    <dt class="col-sm-3">End Date</dt><dd class="col-sm-9">@Model.EndDate.ToShortDateString()</dd>
    <dt class="col-sm-3">Status</dt><dd class="col-sm-9"><span class="badge @(Model.Status == ContractStatus.Active ? "bg-success" : Model.Status == ContractStatus.Expired ? "bg-danger" : "bg-secondary")">@Model.Status</span></dd>
    <dt class="col-sm-3">Service Level</dt><dd class="col-sm-9">@Model.ServiceLevel</dd>
    <dt class="col-sm-3">Signed Agreement</dt><dd class="col-sm-9">@if (!string.IsNullOrEmpty(Model.SignedAgreementPath)) { <a asp-action="Download" asp-route-id="@Model.ContractId" class="btn btn-sm btn-primary">Download PDF</a> } else { <span class="text-muted">Not uploaded</span> }</dd>
</dl>
</div>
<h4>Service Requests</h4>
@if (Model.ServiceRequests.Any()) {
    <table class="table table-sm table-hover"><thead class="table-light"><tr><th>ID</th><th>Description</th><th>USD</th><th>ZAR</th><th>Status</th></tr></thead><tbody>
    @foreach (var sr in Model.ServiceRequests) { <tr><td>@sr.ServiceRequestId</td><td>@sr.Description</td><td>@sr.CostUSD.ToString("C")</td><td>R @sr.CostZAR.ToString("N2")</td><td>@sr.Status</td></tr> }
    </tbody></table>
} else { <p class="text-muted">No service requests yet.</p> }
<a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.ContractId" class="btn btn-success">+ New Request</a>
<a asp-action="Edit" asp-route-id="@Model.ContractId" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>